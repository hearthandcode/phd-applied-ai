#!/bin/sh
# Pre-commit hook: scan for potential PII before allowing a commit
# Installed at .git/hooks/pre-commit — runs on every `git commit`

# Patterns that should NEVER appear in committed session logs or research files
PATTERNS="ssdi|social.security|dosage|prescribed"
PATTERNS="${PATTERNS}|bank.account|routing.number|credit.card|debit.card"
PATTERNS="${PATTERNS}|home.address|mailing.address|phone.number|\bphone\b"
PATTERNS="${PATTERNS}|social.security.number|tax.id|passport.number"
PATTERNS="${PATTERNS}|driver.license|paycheck|salary|wage|\brent\b"
PATTERNS="${PATTERNS}|mortgage|car.payment|loan.payment|monthly.payment"

# Schema fields whose names contain PII keywords but whose VALUES are usually empty
# placeholders or research metadata. These are skipped at the field-name level so the
# the hook doesn't over-match on legitimate schema fields like `medication_notes`.
SAFE_FIELDS="medication_notes|recall_difficulty|cognitive_load"

# Additional high-sensitivity financial terms
FINANCIAL="ssdi_amount|ssdi.check|benefit.amount|disability.payment"

echo "--- Pre-commit PII Scan ---"

# Only scan files that are being committed (staged)
changed_files=$(git diff --cached --name-only --diff-filter=ACM | \
    grep -E '\.(md|txt|csv|json|yaml|yml)$' || true)

if [ -z "$changed_files" ]; then
    echo "  No text files staged — PII scan skipped."
    exit 0
fi

issues=0
for f in $changed_files; do
    # Build the file content with safe-field lines blanked out so the PII pattern
    # scan does not over-match on legitimate schema field names. SAFE_FIELDS
    # includes `medication_notes` (frontmatter placeholder for medication state
    # tracking — the value, not the field name, is what matters and is usually
    # `not-recorded` / `n/a` / empty). The original content is restored after
    # the scan by piping the masked content through grep.
    safe_masked=$(sed -E "s/^(${SAFE_FIELDS}):.*/SAFE_FIELD_REDACTED:/" "$f")
    matches=$(echo "$safe_masked" | grep -n -i -E "$PATTERNS" 2>/dev/null | sed 's|SAFE_FIELD_REDACTED:|<<safe_field_redacted>>:|g' || true)
    if [ -n "$matches" ]; then
        echo "  ⚠ POTENTIAL PII in $f:"
        echo "$matches" | while IFS= read -r line; do
            echo "      $line"
        done
        issues=$((issues + 1))
    fi

    # Check financial-specific terms (higher confidence)
    fin_matches=$(echo "$safe_masked" | grep -n -i -E "$FINANCIAL" 2>/dev/null | sed 's|SAFE_FIELD_REDACTED:|<<safe_field_redacted>>:|g' || true)
    if [ -n "$fin_matches" ]; then
        echo "  🔴 FINANCIAL DATA in $f:"
        echo "$fin_matches" | while IFS= read -r line; do
            echo "      $line"
        done
        issues=$((issues + 5))  # Higher penalty for financial
    fi
done

if [ "$issues" -gt 0 ]; then
    echo ""
    echo "  ⛔ Commit blocked: $issues potential PII issue(s) found."
    echo "  Review flagged lines above. If they're false positives,"
    echo "  commit with --no-verify to bypass this check."
    echo "  ---"
    exit 1
fi

echo "  ✓ No PII patterns detected in staged files."
exit 0